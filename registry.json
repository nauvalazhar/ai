{
  "$schema": "https://ai.nauv.al/schemas/registry.v1.json",
  "name": "ai",
  "homepage": "https://ai.nauv.al",
  "docs": "src/docs",
  "setup": {
    "steps": [
      {
        "type": "assert",
        "name": "tailwind-installed",
        "check": {
          "type": "dependency",
          "packages": ["tailwindcss"]
        },
        "onFail": {
          "exit": true,
          "message": [
            "Tailwind CSS is not installed.",
            "Refer to https://tailwindcss.com/docs/installation for more information."
          ]
        }
      },
      {
        "type": "dependencies",
        "packages": {
          "@base-ui/react": "^1.4.1",
          "class-variance-authority": "^0.7.1",
          "clsx": "^2.1.1",
          "tailwind-merge": "^3.5.0"
        }
      },
      {
        "type": "detect-framework",
        "name": "framework"
      },
      {
        "type": "detect-workdir",
        "name": "workdir",
        "saveAs": "paths.workdir"
      },

      {
        "type": "file-append",
        "target": "{{paths.workdir}}index.css",
        "contentPath": "src/styles/tokens.css",
        "condition": {
          "if": { "type": "framework", "value": "vite" },
          "unless": {
            "any": [
              {
                "type": "file-contains",
                "path": "{{paths.workdir}}index.css",
                "pattern": "--color-surface-elevated"
              }
            ]
          }
        }
      },
      {
        "type": "file-append",
        "target": "{{paths.workdir}}app/globals.css",
        "contentPath": "src/styles/tokens.css",
        "condition": {
          "if": { "type": "framework", "value": "next" },
          "unless": {
            "any": [
              {
                "type": "file-contains",
                "path": "{{paths.workdir}}app/globals.css",
                "pattern": "--color-surface-elevated"
              }
            ]
          }
        }
      },
      {
        "type": "file-append",
        "target": "{{paths.workdir}}app/app.css",
        "contentPath": "src/styles/tokens.css",
        "condition": {
          "if": { "type": "framework", "value": "react-router" },
          "unless": {
            "any": [
              {
                "type": "file-contains",
                "path": "{{paths.workdir}}app/app.css",
                "pattern": "--color-surface-elevated"
              }
            ]
          }
        }
      },
      {
        "type": "file-append",
        "target": "{{paths.workdir}}styles.css",
        "contentPath": "src/styles/tokens.css",
        "condition": {
          "if": {
            "any": [
              { "type": "framework", "value": "tanstack-start" },
              { "type": "framework", "value": "tanstack-router" }
            ]
          },
          "unless": {
            "any": [
              {
                "type": "file-contains",
                "path": "{{paths.workdir}}styles.css",
                "pattern": "--color-surface-elevated"
              }
            ]
          }
        }
      },

      {
        "type": "file-create",
        "target": "{{paths.workdir}}lib/utils.ts",
        "contentPath": "src/lib/utils.ts",
        "saveTargetAs": ["paths.utils"],
        "condition": {
          "if": {
            "any": [
              { "type": "framework", "value": "next" },
              { "type": "framework", "value": "vite" },
              { "type": "framework", "value": "tanstack-start" },
              { "type": "framework", "value": "tanstack-router" }
            ]
          },
          "unless": {
            "any": [
              {
                "type": "file-exists",
                "path": "{{paths.workdir}}lib/utils.ts"
              }
            ]
          }
        }
      },
      {
        "type": "file-create",
        "target": "{{paths.workdir}}app/lib/utils.ts",
        "contentPath": "src/lib/utils.ts",
        "saveTargetAs": ["paths.utils"],
        "condition": {
          "if": { "type": "framework", "value": "react-router" },
          "unless": {
            "any": [
              {
                "type": "file-exists",
                "path": "{{paths.workdir}}app/lib/utils.ts"
              }
            ]
          }
        }
      },

      {
        "type": "context-update",
        "name": "next-vite-tanstack-paths",
        "data": {
          "paths.components": "{{paths.workdir}}components/ai",
          "imports.lib": "@/lib",
          "imports.components/ai": "@/components/ai"
        },
        "condition": {
          "if": {
            "any": [
              { "type": "framework", "value": "next" },
              { "type": "framework", "value": "vite" },
              { "type": "framework", "value": "tanstack-start" },
              { "type": "framework", "value": "tanstack-router" }
            ]
          }
        }
      },
      {
        "type": "context-update",
        "name": "react-router-paths",
        "data": {
          "paths.components": "{{paths.workdir}}app/components/ai",
          "imports.lib": "~/lib",
          "imports.components/ai": "~/components/ai"
        },
        "condition": {
          "if": { "type": "framework", "value": "react-router" }
        }
      }
    ]
  },
  "items": [
    {
      "name": "action",
      "type": "component",
